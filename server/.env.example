# ─────────────────────────────────────────────────────────────
# FitNex Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your actual values below
# 3. NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/fitnex?retryWrites=true&w=majority

# ── JWT Secret ────────────────────────────────────────────────
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum: 32 random bytes (256 bits). Never use simple strings.
JWT_SECRET=replace_with_64_byte_hex_string_generated_via_crypto_randomBytes

# ── Firebase ──────────────────────────────────────────────────
# Same API key as VITE_FIREBASE_API_KEY in client/.env
# Used server-side to verify Firebase ID tokens
FIREBASE_API_KEY=your_firebase_web_api_key_here

# ── Google Gemini AI ──────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Groq (Optional — fallback AI provider) ────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── CORS Origin ───────────────────────────────────────────────
# Set to your frontend URL (comma-separated for multiple)
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ── Server Port ───────────────────────────────────────────────
PORT=5000
